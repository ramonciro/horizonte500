# Supabase: Project → Connect → aba ORMs → Prisma
# DATABASE_URL = pooler modo "transaction" (porta 6543) — usado em runtime
# DIRECT_URL   = pooler modo "session" (porta 5432) — usado só na criação de tabelas
DATABASE_URL="postgresql://postgres.xxxx:SENHA@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# Senha inventada por você para proteger a rota /api/seed (carga inicial de dados)
# Use algo aleatório, ex: gerado em https://1password.com/password-generator
SEED_SECRET="escolha-uma-senha-aleatoria-aqui"
